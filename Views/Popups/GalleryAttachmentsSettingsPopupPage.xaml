<?xml version="1.0" encoding="utf-8" ?>
<controls:BasePopupPage
    xmlns:controls="clr-namespace:GrayWolf.CustomControls"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GrayWolf.ViewModels"
    xmlns:res="clr-namespace:GrayWolf.Localization"
    x:Class="GrayWolf.Views.Popups.GalleryAttachmentsSettingsPopupPage"
    x:DataType="vm:GalleryAttachmentsSettingsPopupViewModel">
    <Grid>
        <StackLayout
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Margin="16"
            Spacing="0"
            BackgroundColor="{StaticResource AppGrayColor}"
            WidthRequest="300">
            <controls:PopupHeader
                Title="{x:Static res:Localization.GalleryAttachmentsSettings_Title}"
                CloseCommand="{Binding BacksCommand}"/>

            <StackLayout
                Padding="12">
                <controls:PopupOptionsView
                    ItemsSource="{Binding Options}"/>

                <Button
                    Command="{Binding ConfirmCommand}"
                    Text="{x:Static res:Localization.Button_Confirm}"
                    Style="{StaticResource ButtonStyle}"/>
            </StackLayout>
        </StackLayout>
    </Grid>
</controls:BasePopupPage>