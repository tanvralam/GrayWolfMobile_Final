<?xml version="1.0" encoding="utf-8" ?>
<popups:BaseLogsPopup
    xmlns:popups="clr-namespace:GrayWolf.Views.Popups"
    x:Class="GrayWolf.Views.Popups.LocationShare"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:domain="clr-namespace:GrayWolf.Models.Domain;assembly=GrayWolf"
    xmlns:vm="clr-namespace:GrayWolf.ViewModels"
    xmlns:local="clr-namespace:GrayWolf.Localization" 
    xmlns:controls="clr-namespace:GrayWolf.CustomControls"
    xmlns:converters="clr-namespace:GrayWolf.Converters"
    x:DataType="vm:LocationShareViewModel"
    x:Name="root">
    <ContentPage.Resources>
        <ResourceDictionary>
            <Style 
                x:Key="LogFileNameStyle" 
                TargetType="Label" 
                x:DataType="domain:LogFile">
                <Setter Property="Text" Value="{Binding Name}"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="HorizontalOptions" Value="FillAndExpand"/>
                <Setter Property="VerticalOptions" Value="CenterAndExpand"/>
                <Setter Property="VerticalTextAlignment" Value="Center"/>
                <Setter Property="TextColor" Value="Gray"/>
                <Style.Triggers>
                    <DataTrigger
                        TargetType="Label"
                        Binding="{Binding IsGraphAvailable}"
                        Value="True">
                        <Setter Property="TextColor" Value="Black"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            
            <Style x:Key="ImageContainerStyle" TargetType="Grid">
                <Setter Property="Margin" Value="0, 5, 0, 0"/>
                <Setter Property="VerticalOptions" Value="FillAndExpand"/>
                <Setter Property="WidthRequest" Value="35"/>
            </Style>

            <Style x:Key="IconStyle" TargetType="Image">
                <Setter Property="HeightRequest" Value="25"/>
                <Setter Property="WidthRequest" Value="25"/>
                <Setter Property="VerticalOptions" Value="CenterAndExpand"/>
                <Setter Property="HorizontalOptions" Value="CenterAndExpand"/>
            </Style>
            
            <Style x:Key="CollectionItemStyle" TargetType="Grid">
                <Setter Property="VisualStateManager.VisualStateGroups">

                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="{OnPlatform Default={StaticResource FileSelectedColor}, WinUI=Transparent}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <ControlTemplate
                x:Key="DefaultCollectionTemplate">
                <CollectionView
                    BindingContext="{TemplateBinding BindingContext}"
                    IsVisible="{Binding LogFilesAvailable}"
                    ItemsSource="{Binding LocationList}"
                    SelectionMode="Single"
                    SelectedItem="{Binding SelectedLog}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate
                            x:DataType="domain:LogFile">
                            <Grid
                                Margin="3,0,15,0"
                                Padding="5"
                                HorizontalOptions="FillAndExpand"
                                RowSpacing="5"
                                VerticalOptions="FillAndExpand"
                                RowDefinitions="auto, 1"
                                Style="{StaticResource CollectionItemStyle}">
                                <StackLayout
                                    Grid.Row="0"
                                    Orientation="Horizontal"
                                    Spacing="5">
                                    <!--  Name  -->
                                    <Label
                                        Style="{StaticResource LogFileNameStyle}"/>
                                    
                                    <!--  Email Icon  -->
                                    <Grid
                                        IsVisible="{OnPlatform Default=False, WinUI=True}"
                                        Style="{StaticResource ImageContainerStyle}">
                                        <Image
                                            Source="email.png"
                                            Style="{StaticResource IconStyle}"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.SendFileByEmailCommand, Source={x:Reference root}}"
                                                CommandParameter="{Binding}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                    <!--  Save Icon  -->
                                    <Grid
                                        IsVisible="{OnPlatform Default=True, iOS=False}"
                                        Style="{StaticResource ImageContainerStyle}">
                                        <Image
                                            Source="save.png"
                                            Style="{StaticResource IconStyle}"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.SaveFileCommand, Source={x:Reference root}}"
                                                CommandParameter="{Binding}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                    <!--  Share Icon  -->
                                    <Grid
                                        Style="{StaticResource ImageContainerStyle}">
                                        <Image
                                            Source="share.png"
                                            Style="{StaticResource IconStyle}"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.ShareFileCommand, Source={x:Reference root}}"
                                                CommandParameter="{Binding}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                    <!--  DataGrid Icon  -->
                                    <Grid
                                        Style="{StaticResource ImageContainerStyle}">
                                        <Image
                                            Opacity="{Binding IsGraphAvailable, Converter={StaticResource IsEnabledToOpacityConverter}}"
                                            Source="{converters:ImageSource ic_data_grid}"
                                            Style="{StaticResource IconStyle}"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference root}, Path=BindingContext.OpenDataGridCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                    <!--  Delete Icon  -->
                                    <Grid
                                        Style="{StaticResource ImageContainerStyle}">
                                        <Image
                                            Source="delete.png"
                                            Style="{StaticResource IconStyle}"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.DeleteFileCommand, Source={x:Reference root}}"
                                                CommandParameter="{Binding}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </StackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ControlTemplate>

            <ControlTemplate
                x:Key="iOSCollectionTemplate">
                <CollectionView
                    BindingContext="{TemplateBinding BindingContext}"
                    IsVisible="{Binding LogFilesAvailable}"
                    ItemsSource="{Binding LocationList}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate
                            x:DataType="domain:LogFile">
                            <Grid
                                Margin="3,0,15,0"
                                Padding="5"
                                HorizontalOptions="FillAndExpand"
                                RowSpacing="5"
                                VerticalOptions="FillAndExpand"
                                RowDefinitions="auto, 1">
                                <Grid.Triggers>
                                    <DataTrigger
                                        Binding="{Binding IsSelected}"
                                        TargetType="Grid"
                                        Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource FileSelectedColor}" />
                                    </DataTrigger>
                                </Grid.Triggers>
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding BindingContext.FileSelectedCommand, Source={x:Reference root}}"
                                        CommandParameter="{Binding}" />
                                </Grid.GestureRecognizers>
                                <StackLayout
                                    Orientation="Horizontal"
                                    Spacing="5">
                                    <!--  Name  -->
                                    <Label
                                        Style="{StaticResource LogFileNameStyle}"/>
                                    
                                    <!--  Email Icon  -->
                                    <Grid
                                        IsVisible="{OnPlatform Default=False, WinUI=True}"
                                        Style="{StaticResource ImageContainerStyle}">
                                        <Image
                                            Source="email.png"
                                            Style="{StaticResource IconStyle}"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.SendFileByEmailCommand, Source={x:Reference root}}"
                                                CommandParameter="{Binding}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                    <!--  Save Icon  -->
                                    <Grid
                                        IsVisible="{OnPlatform Default=True, iOS=False}"
                                        Style="{StaticResource ImageContainerStyle}">
                                        <Image
                                            Source="save.png" 
                                            Style="{StaticResource IconStyle}"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.SaveFileCommand, Source={x:Reference root}}"
                                                CommandParameter="{Binding}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                    <!--  Share Icon  -->
                                    <Grid
                                        Style="{StaticResource ImageContainerStyle}">
                                        <Image
                                            Source="share.png" 
                                            Style="{StaticResource IconStyle}"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.ShareFileCommand, Source={x:Reference root}}"
                                                CommandParameter="{Binding}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                    <!--  DataGrid Icon  -->
                                    <Grid
                                        Style="{StaticResource ImageContainerStyle}">
                                        <Image
                                            Opacity="{Binding HasContent, Converter={StaticResource IsEnabledToOpacityConverter}}"
                                            Source="{converters:ImageSource ic_data_grid}"
                                            Style="{StaticResource IconStyle}"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference root}, Path=BindingContext.OpenDataGridCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                    <!--  Delete Icon  -->
                                    <Grid
                                        Style="{StaticResource ImageContainerStyle}">
                                        <Image
                                            Source="delete.png"
                                            Style="{StaticResource IconStyle}"/>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.DeleteFileCommand, Source={x:Reference root}}"
                                                CommandParameter="{Binding}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </StackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ControlTemplate>

            <ControlTemplate
                x:Key="AllButtonsTemplate">
                <Grid
                    BindingContext="{TemplateBinding BindingContext}"
                    Margin="0,5,0,5"
                    ColumnDefinitions="*, *"
                    WidthRequest="300"
                    HorizontalOptions="Center"
                    RowDefinitions="auto, auto">
                    <Button
                        Grid.Column="0"
                        Grid.Row="0"
                        Command="{Binding AddFileCommand}"
                        Text="{x:Static local:Localization.Locations_Add}"
                        VerticalOptions="Start" 
                        Style="{StaticResource ButtonStyle}" Margin="0,0,10,0"/>

                    <Button
                        Grid.Column="1"
                        Grid.Row="0"
                        Command="{Binding ShareFileCommand}"
                        CommandParameter="{Binding SelectedLog}"
                        Text="{x:Static local:Localization.Locations_Share}"
                        VerticalOptions="Start" 
                        Style="{StaticResource ButtonStyle}"/>

                    <Button
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        BackgroundColor="{StaticResource AppGreenColor}"
                        Command="{Binding ConfirmCommand}"
                        Text="{x:Static local:Localization.Button_Select}"
                        VerticalOptions="Start" 
                        Style="{StaticResource ButtonStyle}" Margin="0,10,0,0"/>
                </Grid>
            </ControlTemplate>
            
            <ControlTemplate
                x:Key="ExportOnlyTemplate">
                <Button
                    BindingContext="{TemplateBinding BindingContext}"
                    Margin="0,5,0,5"
                    WidthRequest="300"
                    Command="{Binding ShareFileCommand}"
                    CommandParameter="{Binding SelectedLog}"
                    Text="{x:Static local:Localization.Locations_Share}"
                    VerticalOptions="Start" 
                    HorizontalOptions="Center"
                    Style="{StaticResource ButtonStyle}"/>
            </ControlTemplate>
        </ResourceDictionary>
            
    </ContentPage.Resources>
    <Grid
        Grid.Row="0"
        BackgroundColor="{StaticResource AppGrayColor}"
       
        VerticalOptions="CenterAndExpand"
        HeightRequest="500"
        HorizontalOptions="Fill"
   
        Margin="20"
        Padding="0, 0, 0, 10"
        RowSpacing="5"
        RowDefinitions="auto, auto, auto, *, auto, auto, auto">
        <controls:PopupHeader
            Grid.Row="0"
            Title="{x:Static local:Localization.Locations_Title}"
            CloseCommand="{Binding CancelCommand}"/>
        <Label
            Grid.Row="1"
            Margin="5,0"
            Text="{x:Static local:Localization.Locations_Hint}" />

        <Label
            Grid.Row="2"
            Margin="5,0"
            FontAttributes="Bold"
            FontSize="18"
            HorizontalOptions="FillAndExpand"
            Text="{x:Static local:Localization.Locations_Locations}"
            TextColor="Black"
            VerticalOptions="FillAndExpand" />

        <!--#endregion-->

        <!--#region List-->
        <Frame
            Grid.Row="3"
            Margin="5,0,5,0"
            Padding="5,5,5,10"
            BackgroundColor="White"
            BorderColor="Gray"
            CornerRadius="5"
            HasShadow="False"
            HorizontalOptions="FillAndExpand"
            IsClippedToBounds="True"
            VerticalOptions="FillAndExpand">
            <VerticalStackLayout>
            <ContentView
                ControlTemplate="{OnPlatform iOS={StaticResource iOSCollectionTemplate}, Default={StaticResource DefaultCollectionTemplate}}"/>
            </VerticalStackLayout>
        </Frame>
        <!--#endregion-->
        <ContentView
            Grid.Row="4"
            ControlTemplate="{StaticResource AllButtonsTemplate}">
            <ContentView.Triggers>
                <DataTrigger
                    TargetType="ContentView"
                    Binding="{Binding ExportButtonsOnly}"
                    Value="True">
                    <Setter Property="ControlTemplate" Value="{StaticResource ExportOnlyTemplate}"/>
                </DataTrigger>
            </ContentView.Triggers>
        </ContentView>
    </Grid>
</popups:BaseLogsPopup>