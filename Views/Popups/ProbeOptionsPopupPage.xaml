<?xml version="1.0" encoding="utf-8" ?>
<controls:BasePopupPage
    xmlns:controls="clr-namespace:GrayWolf.CustomControls"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:loc="clr-namespace:GrayWolf.Localization"
    xmlns:vm="clr-namespace:GrayWolf.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="GrayWolf.Views.Popups.ProbeOptionsPopupPage"
    x:DataType="vm:ProbeOptionsPopupViewModel">
    <Grid>
        <StackLayout
            VerticalOptions="CenterAndExpand"
            HorizontalOptions="Center"
            WidthRequest="400"
            BackgroundColor="{StaticResource AppGrayColor}"
            Spacing="8">
            <controls:PopupHeader
                CloseCommand="{Binding BacksCommand}"
                Title="{x:Static loc:Localization.ProbeOptions_Title}"/>

            <controls:PopupOptionsView
                ItemsSource="{Binding Options}"/>

            <Button
                Command="{Binding ConfirmCommand}"
                Margin="0, 0, 0, 8"
                HorizontalOptions="Center"
                Text="{x:Static loc:Localization.Button_Confirm}"
                Style="{StaticResource ButtonStyle}"/>
        </StackLayout>
    </Grid>
</controls:BasePopupPage>