<?xml version="1.0" encoding="utf-8" ?>
<controls:BasePopupPage
    xmlns:controls="clr-namespace:GrayWolf.CustomControls"
    x:Class="GrayWolf.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:d="http://schemas.microsoft.com/dotnet/2021/maui/design"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:GrayWolf.ViewModels"
    xmlns:res="clr-namespace:GrayWolf.Localization"
    Padding="{StaticResource SmallPopupPadding}"
    mc:Ignorable="d"
    x:DataType="vm:LoginViewModel">
   
        <Grid
            Padding="20"
            BackgroundColor="{StaticResource AppGrayColor}"
            RowSpacing="15"
            VerticalOptions="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="100" />
                <RowDefinition Height="30" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Label
                FontAttributes="Bold"
                FontSize="Large"
                Text="{x:Static res:Localization.Login_AccountRequired}" />
            <Image
                Grid.Row="1"
                HorizontalOptions="Center"
                Source="wolf_head_256.png"
                VerticalOptions="Center"
                WidthRequest="100" />
            <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}" />

            <Entry
                Grid.Row="3"
                Margin="5,5,5,0"
                HorizontalOptions="FillAndExpand"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}"
                Placeholder="{x:Static res:Localization.Login_Username}"
                Text="{Binding Username}"
               
                ReturnType="Next"/>
            <Entry
                Grid.Row="4"
                Margin="5,5,5,0"
                HorizontalOptions="FillAndExpand"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}"
                IsPassword="True"
                Placeholder="{x:Static res:Localization.Login_Password}"
                Text="{Binding Password}" 
                ReturnCommand="{Binding LoginCommand}"/>
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button
                    BackgroundColor="{StaticResource DarkBlue}"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}"
                    Text="{x:Static res:Localization.Login_ButtonText}"
                    TextColor="White" />
                <Button
                    Grid.Column="1"
                    BackgroundColor="{StaticResource AppGrayColor}"
                    Command="{Binding CancelCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}"
                    Text="{x:Static res:Localization.Button_Cancel}"
                    TextColor="Black" />
            </Grid>
        </Grid>

</controls:BasePopupPage>