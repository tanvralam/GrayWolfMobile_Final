<?xml version="1.0" encoding="utf-8" ?>
<controls:BasePopupPage
    xmlns:controls="clr-namespace:GrayWolf.CustomControls"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GrayWolf.ViewModels"
    xmlns:res="clr-namespace:GrayWolf.Localization"
    x:Class="GrayWolf.Views.Popups.WelcomePopupPage"
    x:DataType="vm:WelcomePopupViewModel">
    <Grid>
        <controls:DoNotShowAgainPopupContentView
            Title="{x:Static res:NoTranslation.Welcome_Title}"
            Message="{x:Static res:Localization.Welcome_Message}"
            CloseCommand="{Binding BacksCommand}"
            OkCommand="{Binding ConfirmCommand}"
            DoNotShowAgain="{Binding DoNotShowAgain}"
            CheckBoxTapCommand="{Binding SetDoNotShowAgainCommand}"/>
    </Grid>
</controls:BasePopupPage>
  