<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GrayWolf.ViewModels"
    xmlns:loc="clr-namespace:GrayWolf.Localization"
    xmlns:converters="clr-namespace:GrayWolf.Converters"
    x:Class="GrayWolf.Views.SensorTipsPage"
    x:DataType="vm:SensorTipsPageViewModel"
    Title="{x:Static loc:Localization.SensorTips_Title}">
    <ContentPage.Content>
        <StackLayout
            Spacing="0">
            <StackLayout
                VerticalOptions="Start"
                Spacing="0"
                Padding="12, 8">
                <Label
                    FontAttributes="Bold"
                    FontSize="Small"
                    Text="{x:Static loc:Localization.SensorTips_SensorTip}"/>
                <StackLayout
                    Orientation="Horizontal"
                    Spacing="0">
                    <StackLayout.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding SelectSensorTipCommand}"/>
                    </StackLayout.GestureRecognizers>
                    <Label
                        Text="{Binding SensorTip.CategoryName}"
                        FontSize="Medium"/>
                    <Image
                        VerticalOptions="Center"
                        Source="{converters:ImageSource ic_arrow_right_black}"
                        HeightRequest="24"/>
                </StackLayout>
            </StackLayout>
            <Grid
                VerticalOptions="FillAndExpand">
                <WebView
                    VerticalOptions="FillAndExpand"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InvertBooleanConverter}}"
                    Source="{Binding Html}"/>
                <ActivityIndicator
                    IsRunning="{Binding IsLoading}"
                    IsVisible="{Binding IsLoading}"
                    VerticalOptions="CenterAndExpand"
                    HorizontalOptions="Center"/>
            </Grid>
            <Button
                Command="{Binding SelectSensorTipCommand}"
                Text="{x:Static loc:Localization.SensorTips_ChangeTip}"
                BackgroundColor="{StaticResource AppGreenColor}"
                HorizontalOptions="Center"
                Margin="12"
                Style="{StaticResource ButtonStyle}"/>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>