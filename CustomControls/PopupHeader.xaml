<?xml version="1.0" encoding="utf-8" ?>
<Grid
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="GrayWolf.CustomControls.PopupHeader"
    HeightRequest="50"
    BackgroundColor="{StaticResource AppDarkGrayColor}"
    HorizontalOptions="FillAndExpand"
    VerticalOptions="FillAndExpand"
    RowDefinitions="50"
    ColumnDefinitions="50, *, 50"
    x:Name="popupHeader">
    <Label
        Grid.Row="0"
        Grid.Column="1"
        Text="{Binding Source={x:Reference popupHeader}, Path=Title}"
        Style="{StaticResource PopupTitleStyle}"/>

    <Grid
        Grid.Column="2"
        Grid.Row="0">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer 
                Command="{Binding Source={x:Reference popupHeader}, Path=CloseCommand}" />
        </Grid.GestureRecognizers>
        <Image
            Style="{StaticResource PopupCloseIconStyle}"/>
    </Grid>
</Grid>