<?xml version="1.0" encoding="UTF-8"?>
<StackLayout
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui" 
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
    xmlns:controls="clr-namespace:GrayWolf.CustomControls"
    xmlns:res="clr-namespace:GrayWolf.Localization"
    x:Class="GrayWolf.CustomControls.DoNotShowAgainPopupContentView"
    x:Name="PopupContent"
    BackgroundColor="{StaticResource AppGrayColor}"
    HorizontalOptions="Center"
    VerticalOptions="Center"
    WidthRequest="300"
    Margin="16"
    Spacing="8">
    <controls:PopupHeader
        Title="{Binding Source={x:Reference PopupContent}, Path=Title}"
        CloseCommand="{Binding Source={x:Reference PopupContent}, Path=CloseCommand}"/>

    <Label
        Text="{Binding Source={x:Reference PopupContent}, Path=Message}"
        FontSize="{Binding Source={x:Reference PopupContent}, Path=MessageTextSize}"
        Margin="12, 4"
        HorizontalTextAlignment="Center"/>

    <Grid
        ColumnDefinitions="auto, *"
        Margin="12, 0">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer
                Tapped="DoNotShowAgain_Tapped"/>
        </Grid.GestureRecognizers>
        <CheckBox
            Grid.Column="0"
            x:Name="CheckBox"
            InputTransparent="True"
            IsChecked="{Binding Source={x:Reference PopupContent}, Path=DoNotShowAgain, Mode=OneWay}"/>
        <BoxView
            Grid.Column="0"
            BackgroundColor="Transparent"/>
        <Label
            Grid.Column="1"
            Text="{x:Static res:Localization.DoNotShowAgain}"
            VerticalTextAlignment="Center"/>
    </Grid>

    <Button
        Text="{x:Static res:Localization.Button_Ok}"
        Command="{Binding Source={x:Reference PopupContent}, Path=OkCommand}"
        Style="{StaticResource ButtonStyle}"
        Margin="12, 8, 12, 12"/>
</StackLayout>